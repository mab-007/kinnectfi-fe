{
  "expo": {
    "name": "Kinnectfi",
    "slug": "kinnectfi",
    "scheme": "kinnectfi",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "fi.kinnect.app"
    },
    "android": {
      "package": "fi.kinnect.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F4EFE7"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Use Face ID to quickly and securely unlock Kinnectfi."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 180,
          "resizeMode": "contain",
          "backgroundColor": "#F4EFE7"
        }
      ],
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "Kinnectfi uses your camera to verify your identity (ID scan and selfie).",
          "microphonePermission": "Kinnectfi uses your microphone during identity verification."
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": { "deploymentTarget": "17.5" }
        }
      ]
    ]
  }
}
