# Backend base URL. iOS simulator + web can use localhost; a physical device on
# the same wifi needs your machine's LAN IP (e.g. http://192.168.1.20:3000).
EXPO_PUBLIC_API_URL=http://localhost:3000

# Auth mode. Unset/"privy" = real Privy login. "fake" = dev bypass: sign in with
# any dummy email + the fixed OTP 000000, no real SMS/inbox needed. Pair with the
# BE running AUTH_MODE=fake (the BE refuses fake auth in production). Restart Expo
# with `pnpm start -c` after changing this.
EXPO_PUBLIC_AUTH_MODE=
